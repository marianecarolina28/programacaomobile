<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mariane Nails</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
<link rel="stylesheet" href="style.css">
</head>

<body>

<header>
<h1>Mariane Nails</h1>
<nav>
<a href="#home">Home</a>
<a href="#servicos">Serviços</a>
<a href="#galeria">Galeria</a>
<a href="#contato">Contato</a>
</nav>
<button id="darkModeToggle">🌙</button>
</header>

<main>

<section id="home" class="hero">
<h2>Unhas perfeitas 💅</h2>
<p>Agende seu horário agora</p>
<a href="https://wa.me/5512988838947" class="btn">WhatsApp</a>
</section>

<section id="servicos">
<h2>Serviços</h2>
<div class="cards">
<article>Manicure</article>
<article>Pedicure</article>
<article>Unhas em gel</article>
<article>Nail art</article>
</div>
</section>

<section id="galeria">
<h2>Galeria</h2>
<div class="grid">
<img src=java script/decorada em gel rosa.jpg>
<img src=java script/unha em gel branca.jpg>
<img src=java script/francesinha em gel simples.jpg>
<img src=java script/unha decorada azul bebê simples.jpg>
<img src=java script/roxo simples.jpg>
<img src=java script/unha vermelho simples.jpg>
<img src=java script/marrom simples.jpg>
<img src=java script/nail art com laços.jpg>
<img src=java script/nail art limãozinho.jpg>
<img src=java script/nail art verão.jpg>
<img src=java script/nail art.jpg>
<img src=java script/francesinha com decoração no pé rosa bebê.jpg>
<img src=java script/francesinha no pé.jpg>
</div>
</section>

<section id="contato">
<h2>Agendamento</h2>
<form id="formAgendamento">
<input type="text" id="nome" placeholder="Nome" required>
<input type="date" id="data" required>
<input type="time" id="hora" required>
<button type="submit">Agendar</button>
</form>

<p id="msg"></p>

<h3>Agendamentos:</h3>
<ul id="lista"></ul>
</section>

</main>

<footer>
<p>© 2026 Mariane Nails</p>
</footer>

<script>
// DARK MODE
const toggle = document.getElementById('darkModeToggle');
toggle.onclick = () => document.body.classList.toggle('dark');

// AGENDAMENTO
const form = document.getElementById('formAgendamento');
const lista = document.getElementById('lista');
const msg = document.getElementById('msg');

function carregar(){
 const dados = JSON.parse(localStorage.getItem('agendamentos')) || [];
 lista.innerHTML = '';
 dados.forEach((item, index) => {
   const li = document.createElement('li');
   li.innerHTML = `${item.nome} - ${item.data} às ${item.hora} 
   <button onclick="remover(${index})">❌</button>`;
   lista.appendChild(li);
 });
}

function remover(index){
 let dados = JSON.parse(localStorage.getItem('agendamentos')) || [];
 dados.splice(index,1);
 localStorage.setItem('agendamentos', JSON.stringify(dados));
 carregar();
}

form.addEventListener('submit', function(e){
 e.preventDefault();

 const nome = document.getElementById('nome').value;
 const data = document.getElementById('data').value;
 const hora = document.getElementById('hora').value;

 const hoje = new Date();
 const escolhida = new Date(`${data}T${hora}`);

 if(escolhida < hoje){
   msg.innerText = "Escolha uma data/hora válida! ⚠️";
   return;
 }

 const novo = { nome, data, hora };
 const dados = JSON.parse(localStorage.getItem('agendamentos')) || [];
 dados.push(novo);
 localStorage.setItem('agendamentos', JSON.stringify(dados));

 msg.innerText = "Agendamento salvo! 💖";
 form.reset();
 carregar();
});

carregar();
</script>

</body>
</html>